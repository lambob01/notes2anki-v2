# Required for AI card generation
OPENAI_API_KEY=

# Any OpenAI-compatible API base URL can be used.
# For OpenAI directly, use: https://api.openai.com/v1
BASE_URL=https://api.openai.com/v1

# Use a vision-capable model.
MODEL_NAME=gpt-4o-mini

# Local AnkiConnect endpoint.
ANKI_URL=http://127.0.0.1:8765

# Defaults used when CLI flags are not supplied.
DEFAULT_DECK_NAME=Default
DEFAULT_NOTE_TYPE=Notes2Anki

# Processing defaults.
POLL_INTERVAL=3
DPI=150
MAX_WORKERS=4
